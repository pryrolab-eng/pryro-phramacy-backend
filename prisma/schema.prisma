  plan                                                              subscription_plan?
  start_date                                                        DateTime?                       @default(now()) @db.Timestamptz(6)
  end_date                                                          DateTime?                       @db.Timestamptz(6)
  is_active                                                         Boolean?                        @default(true)
  amount                                                            Decimal?                        @default(0.00) @db.Decimal(10, 2)
  currency                                                          String?                         @default("RWF")
  payment_reference                                                 String?
  created_at                                                        DateTime?                       @default(now()) @db.Timestamptz(6)
  updated_at                                                        DateTime?                       @default(now()) @db.Timestamptz(6)
  expires_at                                                        DateTime?                       @db.Timestamptz(6)
  payment_method                                                    String?
  plan_id                                                           String?                         @db.Uuid
  trial_ends_at                                                     DateTime?                       @db.Timestamptz(6)
  cancelled_at                                                      DateTime?                       @db.Timestamptz(6)
  cancel_reason                                                     String?
  renewed_at                                                        DateTime?                       @db.Timestamptz(6)
  billing_cycle_start                                               DateTime?                       @default(now()) @db.Timestamptz(6)
  branch_id                                                         String?                         @db.Uuid
  subscription_type                                                 String                          @default("main")
  status                                                            String                          @default("pending")
  current_period_start                                              DateTime?                       @default(now()) @db.Timestamptz(6)
  current_period_end                                                DateTime?                       @db.Timestamptz(6)
  suspended_at                                                      DateTime?                       @db.Timestamptz(6)
  reactivated_at                                                    DateTime?                       @db.Timestamptz(6)
  billing_period                                                    String                          @default("monthly")
  next_plan_id                                                      String?                         @db.Uuid
  change_scheduled_at                                               DateTime?                       @db.Timestamptz(6)
  change_type                                                       String?
  pending_change_status                                             String?
  branch_usage                                                      branch_usage[]
  payment_transactions                                              payment_transactions[]
  subscription_change_events                                        subscription_change_events[]
  subscription_invoice_lines                                        subscription_invoice_lines[]
  subscription_notification_log                                     subscription_notification_log[]
  branches                                                          branches?                       @relation(fields: [branch_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subscription_plans_subscriptions_next_plan_idTosubscription_plans subscription_plans?             @relation("subscriptions_next_plan_idTosubscription_plans", fields: [next_plan_id], references: [id], onUpdate: NoAction)
  pharmacies                                                        pharmacies?                     @relation(fields: [pharmacy_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  subscription_plans_subscriptions_plan_idTosubscription_plans      subscription_plans?             @relation("subscriptions_plan_idTosubscription_plans", fields: [plan_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

