/// Server-side sessions for native Pryrox auth (VPS mode).
model app_sessions {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String     @db.Uuid
  token_hash String     @unique
  expires_at DateTime   @db.Timestamptz(6)
  created_at DateTime   @default(now()) @db.Timestamptz(6)
  user_agent String?
  ip         String?    @db.Inet
  users      auth_users @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([user_id], map: "idx_app_sessions_user_id")
  @@index([expires_at], map: "idx_app_sessions_expires_at")
  @@schema("public")
}

