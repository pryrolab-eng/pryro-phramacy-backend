# Pryrox Nest API — copy from repo root .env or symlink.
# Runtime queries use the pooler URL (pgbouncer=true).

DATABASE_URL=postgresql://postgres.your-ref:your-password@aws-0-your-region.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DIRECT_URL=postgresql://postgres.your-ref:your-password@aws-0-your-region.pooler.supabase.com:5432/postgres?sslmode=require

AUTH_SECRET=generate-a-random-string-at-least-32-characters-long
NATIVE_AUTH_ENABLED=true

PORT=4000
NODE_ENV=development

# Base URL of the Next.js frontend app (used in email links)
APP_URL=http://localhost:3000
# Fallback used if APP_URL is not set
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated origins allowed for CORS
CORS_ORIGINS=http://localhost:3000

# SMTP for all transactional emails (auth, staff invites, maintenance notices)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Pryrox" <no-reply@pryrox.com>
# Set to "true" for port 465 (implicit TLS)
SMTP_SECURE=false

# Redis — required for BullMQ maintenance notification queue (optional; queue skipped when unset)
# REDIS_URL=redis://default:password@your-redis-host:6379
# Or individual fields:
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Google OAuth (optional — enables Google sign-in)
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret

# NVIDIA AI (optional — enables AI chat and drug safety analysis)
# NVIDIA_API_KEY=nvapi-your-key-here
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
# NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# ClickHouse analytics (optional — falls back to Postgres when unset)
# CLICKHOUSE_URL=http://localhost:8123
# CLICKHOUSE_USER=pryrox
# CLICKHOUSE_PASSWORD=pryrox_dev
# CLICKHOUSE_DATABASE=pryrox_analytics

# Cron secret — external schedulers must send Authorization: Bearer <CRON_SECRET>
CRON_SECRET=your-random-cron-secret

# Auto-cancel pending payments/subscriptions after N days (default: 7)
PENDING_PAYMENT_EXPIRE_DAYS=7
